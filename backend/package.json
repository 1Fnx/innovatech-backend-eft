{
  "name": "tienda-perritos-backend",
  "version": "1.0.0",
  "description": "API backend para tienda de alimentos para perritos - Innovatech Chile",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "test": "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "mysql2": "^3.9.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  },
  "packageManager": "pnpm@9.0.0"
}
